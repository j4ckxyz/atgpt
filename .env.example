# Required. Signs the account (DID) session cookie used for cross-device sync.
# Must be a long random string (>= 16 chars). Generate one with:
#   openssl rand -base64 32
AUTH_SECRET=

# Optional. Where the SQLite database file lives.
# Defaults to ./data/atgpt.db (local) or /app/data/atgpt.db (Docker).
# DATABASE_PATH=./data/atgpt.db

# Optional. Defaults to https://console.cocore.dev when unset.
# Override only if you point at a different co/core deployment.
# COCORE_BASE_URL=https://console.cocore.dev

# Optional. Server-wide fallback Gemini API key for AT Personalisation.
# Per-account keys set in /settings take precedence. Get one (free tier) at
# https://aistudio.google.com/apikey
# GEMINI_API_KEY=
